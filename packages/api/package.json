{
  "name": "@openrelay/api",
  "version": "0.0.1",
  "private": true,
  "description": "OpenRelay REST API — the merchant-facing gateway",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openrelay/protocol": "workspace:*",
    "@fastify/cors": "^11.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "fastify": "^5.7.2",
    "ioredis": "^5.4.1",
    "nanoid": "^5.1.11",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.4",
    "viem": "^2.48.7",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
