{
  "name": "@openrelay/api",
  "version": "0.0.1",
  "private": true,
  "description": "OpenRelay REST API — the merchant-facing gateway",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openrelay/protocol": "workspace:*",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.1",
    "nanoid": "^5.0.7",
    "pino-pretty": "^11.2.0",
    "postgres": "^3.4.4",
    "viem": "^2.17.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.15.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
