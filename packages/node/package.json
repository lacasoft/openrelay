{
  "name": "@openrelay/node",
  "version": "0.0.1",
  "private": true,
  "description": "OpenRelay node daemon — runs a community routing node",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@openrelay/protocol": "workspace:*",
    "better-sqlite3": "^12.9.0",
    "fastify": "^5.7.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "viem": "^2.48.7",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
