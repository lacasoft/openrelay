  "version": "0.0.1",
  "type": "library",
  "license": "Apache-2.0",
  "require": {
    "php": ">=8.1",
    "guzzlehttp/guzzle": "^7.8"
  },
  "autoload": {
    "psr-4": { "OpenRelay\\": "src/" }
  },
