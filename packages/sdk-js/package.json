{
  "name": "@openrelay/sdk",
  "version": "0.0.1",
  "description": "OpenRelay JavaScript/TypeScript SDK — the Stripe-compatible payment SDK for the open web",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": ["payments", "web3", "usdc", "base", "x402", "openrelay"],
  "license": "Apache-2.0",
  "dependencies": {
    "@openrelay/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
